{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Core permissions for the Ouroboros Chat window with shell and file system access for agents.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-kill",
    "fs:allow-read-all",
    "fs:allow-write-all",
    "fs:allow-create-all",
    "fs:allow-remove-all",
    "fs:allow-copy-file",
    "fs:allow-rename",
    "fs:allow-mkdir"
  ]
}
